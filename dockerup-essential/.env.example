# Minimal .env template used by docker-compose.yml
# Copy this file to .env in the same folder as docker-compose.yml

# Ubuntu deploy path (recommended)
STORAGE_PATH=/mnt/md127/WIFI_YFP_DashBoard

# Windows local test example (optional)
# STORAGE_PATH=.
API_REQUEST_TIMEOUT=30

# ========== 安全配置 ==========
# 啟用 HTTPS（需要SSL證書）
# ENABLE_HTTPS=false
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# CORS 允許的源（多個源用逗號分隔）
CORS_ALLOWED_ORIGINS=http://10.88.88.250:8000,http://10.88.88.250:3000

# ========== 開發調試配置 ==========
# 僅在開發環境使用
# DEBUG=false
# RELOAD_ON_CHANGE=true

# ========== 備註 ==========
#
# 更改這些環境變數後，需要重新啟動容器：
#   docker-compose down
#   docker-compose up -d --build
#
# 直接編輯 .env 檔案：
#   nano .env
#
# 驗證環境變數是否已正確讀取：
#   docker-compose config
#
# 查看容器環境變數：
#   docker exec wifitest-api env
#
