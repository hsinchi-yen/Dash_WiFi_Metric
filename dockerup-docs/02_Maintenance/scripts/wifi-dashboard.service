[Unit]
Description=WiFi Dashboard Docker Compose Stack
After=network-online.target docker.service mnt-md0.mount wifi-md0-mount.service
Wants=network-online.target wifi-md0-mount.service
Requires=docker.service
RequiresMountsFor=/mnt/md0/WIFI_YFP_DashBoard

[Service]
Type=oneshot
WorkingDirectory=/mnt/md0/WIFI_YFP_DashBoard/dockerup-essential
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
RemainAfterExit=yes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
